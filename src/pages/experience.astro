---
const researchExperience = [
  {
    title: "Add research role here",
    organization: "Institution / Lab Name",
    period: "Year – Present",
    description:
      "Add a short description of your research role, the main problems you worked on, and the methods or tools you used.",
  },
  {
    title: "Add previous research role here",
    organization: "Institution / Group Name",
    period: "Year – Year",
    description:
      "Add a short description of your contributions, research focus, or technical responsibilities.",
  },
];

const professionalExperience = [
  {
    title: "Add professional role here",
    organization: "Company / Organization Name",
    period: "Year – Year",
    description:
      "Add a short description of your responsibilities, technical work, and notable outcomes.",
  },
];

const leadershipService = [
  {
    title: "Add teaching / mentoring / service role here",
    organization: "Institution / Organization",
    period: "Year – Year",
    description:
      "Add a short description of your teaching, leadership, mentoring, reviewing, or service activities.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Experience | Your Name</title>
    <meta
      name="description"
      content="Experience page for Your Name, including research experience, professional experience, and leadership or service activities."
    />
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>

  <body class="bg-slate-950 text-white overflow-x-hidden">
    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-wide text-white">
          Your Name
        </a>

        <div class="hidden gap-6 text-sm text-slate-300 md:flex">
          <a href="/" class="transition hover:text-cyan-300">Home</a>
          <a href="/about" class="transition hover:text-cyan-300">About</a>
          <a href="/research" class="transition hover:text-cyan-300">Research</a>
          <a href="/publications" class="transition hover:text-cyan-300">Publications</a>
          <a href="/experience" class="transition hover:text-cyan-300">Experience</a>
          <a href="/news" class="transition hover:text-cyan-300">News</a>
          <a href="/#contact" class="transition hover:text-cyan-300">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <!-- Hero -->
      <section class="relative overflow-hidden px-6 py-24">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-400/5 blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Experience
          </p>
          <h1 class="mt-4 text-4xl font-bold sm:text-5xl">
            Professional Trajectory
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            A summary of my research experience, professional work, and academic
            service across engineering, estimation, and machine learning.
          </p>
        </div>
      </section>

      <!-- Research Experience -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Research Experience
          </p>
          <h2 class="mt-3 text-3xl font-bold">Research roles and projects</h2>

          <div class="mt-10 space-y-6">
            {researchExperience.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                  <div>
                    <h3 class="text-2xl font-semibold">{item.title}</h3>
                    <p class="mt-1 text-slate-400">{item.organization}</p>
                  </div>
                  <p class="text-sm font-medium text-cyan-300/90">{item.period}</p>
                </div>

                <p class="mt-5 leading-8 text-slate-300">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Professional Experience -->
      <section class="px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Professional Experience
          </p>
          <h2 class="mt-3 text-3xl font-bold">Industry and applied work</h2>

          <div class="mt-10 space-y-6">
            {professionalExperience.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                  <div>
                    <h3 class="text-2xl font-semibold">{item.title}</h3>
                    <p class="mt-1 text-slate-400">{item.organization}</p>
                  </div>
                  <p class="text-sm font-medium text-cyan-300/90">{item.period}</p>
                </div>

                <p class="mt-5 leading-8 text-slate-300">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Leadership & Service -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Leadership & Service
          </p>
          <h2 class="mt-3 text-3xl font-bold">Teaching, mentoring, and service</h2>

          <div class="mt-10 space-y-6">
            {leadershipService.map((item) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                  <div>
                    <h3 class="text-2xl font-semibold">{item.title}</h3>
                    <p class="mt-1 text-slate-400">{item.organization}</p>
                  </div>
                  <p class="text-sm font-medium text-cyan-300/90">{item.period}</p>
                </div>

                <p class="mt-5 leading-8 text-slate-300">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Closing -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Summary
          </p>
          <h2 class="mt-3 text-3xl font-bold">An evolving professional profile</h2>
          <p class="mx-auto mt-6 max-w-3xl leading-8 text-slate-300">
            This page can grow over time as additional research appointments,
            internships, teaching roles, and service contributions are added.
          </p>

          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a
              href="/about"
              class="rounded-xl border border-cyan-300/30 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:bg-cyan-300/10"
            >
              About me
            </a>
            <a
              href="/research"
              class="rounded-xl border border-cyan-300/30 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:bg-cyan-300/10"
            >
              Explore research
            </a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>