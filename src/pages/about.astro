---
const skills = {
  programming: ["Python", "MATLAB", "C/C++", "SQL"],
  tools: ["Machine Learning", "Data Analysis", "Numerical Methods", "Scientific Computing"],
  domains: ["State Estimation", "Filtering", "Space Systems", "Engineering Materials"],
};

const quickLinks = [
  { label: "CV", href: "/cv.pdf" },
  { label: "Resume", href: "/resume.pdf" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/YOUR-LINKEDIN/" },
  { label: "Google Scholar", href: "https://scholar.google.com/" },
  { label: "ResearchGate", href: "https://www.researchgate.net/profile/YOUR-RESEARCHGATE" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>About | Your Name</title>
    <meta
      name="description"
      content="About page for Your Name, featuring academic background, research interests, technical skills, and professional profile."
    />
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>

  <body class="bg-slate-950 text-white overflow-x-hidden">
    <!-- Top navigation -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-wide text-white">
          Your Name
        </a>

        <div class="hidden gap-6 text-sm text-slate-300 md:flex">
          <a href="/" class="transition hover:text-cyan-300">Home</a>
          <a href="/about" class="transition hover:text-cyan-300">About</a>
          <a href="/research" class="transition hover:text-cyan-300">Research</a>
          <a href="/publications" class="transition hover:text-cyan-300">Publications</a>
          <a href="/#updates" class="transition hover:text-cyan-300">Updates</a>
          <a href="/#contact" class="transition hover:text-cyan-300">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <!-- Hero -->
      <section class="relative overflow-hidden px-6 py-24">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-400/5 blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            About
          </p>
          <h1 class="mt-4 text-4xl font-bold sm:text-5xl">
            Academic and professional profile
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            I am a researcher interested in estimation, autonomy, machine learning,
            and their applications to engineering systems. My current work spans
            space-state estimation and AI/ML for engineering materials.
          </p>
        </div>
      </section>

      <!-- Main profile -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[320px_1fr]">
          <!-- Left card -->
          <aside class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
            <img
              src="/profile.jpg"
              alt="Profile photo"
              class="mx-auto h-40 w-40 rounded-full border border-white/20 object-cover"
            />

            <div class="mt-6 text-center">
              <h2 class="text-2xl font-bold">Your Name</h2>
              <p class="mt-2 text-sm leading-6 text-slate-300">
                Researcher in space systems, estimation, autonomy, and machine learning
              </p>
            </div>

            <div class="mt-6 space-y-3 text-sm text-slate-300">
              <p><span class="font-semibold text-white">Affiliation:</span> Add your institution</p>
              <p><span class="font-semibold text-white">Location:</span> Add your location</p>
              <p><span class="font-semibold text-white">Email:</span> Add your email</p>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              {quickLinks.map((link) => (
                <a
                  href={link.href}
                  target={link.href.startsWith("http") ? "_blank" : "_self"}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:border-cyan-300/40 hover:bg-cyan-300/10"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </aside>

          <!-- Right content -->
          <div class="space-y-10">
            <section class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl backdrop-blur">
              <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
                Biography
              </p>
              <h2 class="mt-3 text-3xl font-bold">Who I am</h2>
              <p class="mt-6 leading-8 text-slate-300">
                Add a short academic biography here. A good version is about one
                or two paragraphs and should explain your background, current
                academic position, major research interests, and broader goals.
              </p>
              <p class="mt-4 leading-8 text-slate-300">
                You can also mention the intersection of your two current research
                directions: space autonomy, navigation, and estimation, as well as
                AI/ML for engineering materials.
              </p>
            </section>

            <section class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl backdrop-blur">
              <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
                Education
              </p>
              <h2 class="mt-3 text-3xl font-bold">Academic background</h2>

              <div class="mt-6 space-y-6">
                <div>
                  <h3 class="text-xl font-semibold">Add your degree here</h3>
                  <p class="mt-1 text-slate-400">Institution Name · Year or Expected Year</p>
                  <p class="mt-3 leading-7 text-slate-300">
                    Add a short description if needed, such as thesis title,
                    concentration, advisor, or research focus.
                  </p>
                </div>

                <div>
                  <h3 class="text-xl font-semibold">Add previous degree here</h3>
                  <p class="mt-1 text-slate-400">Institution Name · Year</p>
                  <p class="mt-3 leading-7 text-slate-300">
                    Add a short description if useful.
                  </p>
                </div>
              </div>
            </section>

            <section class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl backdrop-blur">
              <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
                Research Interests
              </p>
              <h2 class="mt-3 text-3xl font-bold">Current directions</h2>

              <div class="mt-6 grid gap-6 md:grid-cols-2">
                <article class="rounded-2xl border border-white/10 bg-slate-900/50 p-6">
                  <h3 class="text-2xl font-semibold">
                    Space Autonomy, Navigation, and Estimation
                  </h3>
                  <p class="mt-4 leading-7 text-slate-300">
                    This area includes state estimation, filtering, navigation,
                    and autonomy-related methods for space applications, including
                    polynomial Kalman filtering and related frameworks.
                  </p>
                </article>

                <article class="rounded-2xl border border-white/10 bg-slate-900/50 p-6">
                  <h3 class="text-2xl font-semibold">
                    AI/ML for Engineering Materials
                  </h3>
                  <p class="mt-4 leading-7 text-slate-300">
                    This area includes machine learning approaches for predicting
                    and understanding the mechanical and wear characterization of
                    composites and other engineering material systems.
                  </p>
                </article>
              </div>
            </section>

            <section class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl backdrop-blur">
              <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
                Skills
              </p>
              <h2 class="mt-3 text-3xl font-bold">Technical profile</h2>

              <div class="mt-6 grid gap-6 md:grid-cols-3">
                <div>
                  <h3 class="text-lg font-semibold">Programming</h3>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {skills.programming.map((item) => (
                      <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm text-slate-200">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>

                <div>
                  <h3 class="text-lg font-semibold">Tools & Methods</h3>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {skills.tools.map((item) => (
                      <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm text-slate-200">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>

                <div>
                  <h3 class="text-lg font-semibold">Domains</h3>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {skills.domains.map((item) => (
                      <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm text-slate-200">
                        {item}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </section>

            <section class="rounded-3xl border border-white/10 bg-white/5 p-8 shadow-xl backdrop-blur">
              <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
                Outlook
              </p>
              <h2 class="mt-3 text-3xl font-bold">Looking ahead</h2>
              <p class="mt-6 leading-8 text-slate-300">
                Add a short forward-looking statement here about the kinds of
                problems you want to work on, future collaborations you are open to,
                or the broader impact you want your research to have.
              </p>

              <div class="mt-8 flex flex-wrap gap-3">
                <a
                  href="/research"
                  class="rounded-xl border border-cyan-300/30 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:bg-cyan-300/10"
                >
                  Explore research
                </a>
                <a
                  href="/publications"
                  class="rounded-xl border border-cyan-300/30 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:bg-cyan-300/10"
                >
                  View publications
                </a>
              </div>
            </section>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>