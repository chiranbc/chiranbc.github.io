---
const spaceProjects = [
  {
    title: "Polynomial Kalman Filtering for Space Applications",
    description:
      "Research focused on advanced state-estimation and filtering methods for space-related applications, with emphasis on polynomial Kalman filtering and related estimation frameworks.",
    status: "Current Research",
  },
  {
    title: "Future Work in Space-State Estimation",
    description:
      "This section can later include additional work in navigation, autonomy, uncertainty-aware estimation, and filtering methods for aerospace systems.",
    status: "Future Direction",
  },
];

const materialsProjects = [
  {
    title: "ML-Based Prediction of Mechanical and Wear Characterization of Composites",
    description:
      "Research on machine learning methods for predicting mechanical and wear behavior of composite materials, with applications to engineering material characterization.",
    status: "Current Research",
  },
  {
    title: "Future Work in AI/ML for Engineering Materials",
    description:
      "This section can later include additional work in data-driven materials modeling, predictive analytics, and material performance characterization.",
    status: "Future Direction",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Research | Your Name</title>
    <meta
      name="description"
      content="Research areas and projects in space autonomy, navigation, estimation, and AI/ML for engineering materials."
    />
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>

  <body class="bg-slate-950 text-white overflow-x-hidden">
    <!-- top navigation -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-wide text-white">
          Your Name
        </a>

        <div class="hidden gap-6 text-sm text-slate-300 md:flex">
          <a href="/" class="transition hover:text-cyan-300">Home</a>
          <a href="/research" class="transition hover:text-cyan-300">Research</a>
          <a href="/#publications" class="transition hover:text-cyan-300">Publications</a>
          <a href="/#updates" class="transition hover:text-cyan-300">Updates</a>
          <a href="/#contact" class="transition hover:text-cyan-300">Contact</a>
        </div>
      </nav>
    </header>

    <!-- page hero -->
    <main>
      <section class="relative overflow-hidden px-6 py-24">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-400/5 blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Research
          </p>
          <h1 class="mt-4 text-4xl font-bold sm:text-5xl">
            Research Constellations
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            My work currently spans two broad directions: space autonomy,
            navigation, and estimation; and AI/ML for engineering materials.
            These themes are designed to grow as my research expands.
          </p>
        </div>
      </section>

      <!-- research area 1 -->
      <section id="space-estimation" class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-6xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Research Area 1
          </p>
          <h2 class="mt-3 text-3xl font-bold">
            Space Autonomy, Navigation, and Estimation
          </h2>
          <p class="mt-5 max-w-3xl leading-8 text-slate-300">
            This area focuses on estimation, filtering, and autonomy-related
            methods for space applications. It includes current work in
            polynomial Kalman filtering and can later grow into broader topics
            such as navigation, uncertainty-aware estimation, and autonomous
            aerospace systems.
          </p>

          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {spaceProjects.map((project) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <p class="text-sm uppercase tracking-wide text-cyan-300/80">
                  {project.status}
                </p>
                <h3 class="mt-3 text-2xl font-semibold">{project.title}</h3>
                <p class="mt-4 leading-7 text-slate-300">{project.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- research area 2 -->
      <section id="materials-ml" class="px-6 py-20">
        <div class="mx-auto max-w-6xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Research Area 2
          </p>
          <h2 class="mt-3 text-3xl font-bold">
            AI/ML for Engineering Materials
          </h2>
          <p class="mt-5 max-w-3xl leading-8 text-slate-300">
            This area focuses on machine learning approaches for engineering
            materials, especially predictive modeling of mechanical and wear
            characterization in composites. It can later expand into broader
            data-driven materials modeling and materials informatics topics.
          </p>

          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {materialsProjects.map((project) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <p class="text-sm uppercase tracking-wide text-cyan-300/80">
                  {project.status}
                </p>
                <h3 class="mt-3 text-2xl font-semibold">{project.title}</h3>
                <p class="mt-4 leading-7 text-slate-300">{project.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- closing section -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Outlook
          </p>
          <h2 class="mt-3 text-3xl font-bold">An expanding research profile</h2>
          <p class="mx-auto mt-6 max-w-3xl leading-8 text-slate-300">
            These two research directions provide a flexible structure for
            presenting both current work and future related projects, papers,
            and collaborations.
          </p>

          <a
            href="/#contact"
            class="mt-8 inline-block rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-medium text-white transition hover:border-cyan-300/40 hover:bg-cyan-300/10"
          >
            Get in touch
          </a>
        </div>
      </section>
    </main>
  </body>
</html>