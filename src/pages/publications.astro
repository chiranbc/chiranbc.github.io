---
const featuredPublications = [
  {
    title: "Add your featured publication title here",
    authors: "Your Name, Coauthor Name, Coauthor Name",
    venue: "Journal / Conference, Year",
    description:
      "A short 1–2 sentence summary of the publication and why it matters.",
    links: [
      { label: "Paper", href: "#" },
      { label: "DOI", href: "#" },
      { label: "Code", href: "#" },
    ],
  },
  {
    title: "Add your second featured publication here",
    authors: "Your Name, Coauthor Name",
    venue: "Journal / Conference, Year",
    description:
      "A short summary describing the contribution, application, or methodology.",
    links: [
      { label: "Paper", href: "#" },
      { label: "Preprint", href: "#" },
    ],
  },
];

const journalPapers = [
  {
    title: "Add journal paper title here",
    authors: "Your Name, Coauthor Name, Coauthor Name",
    venue: "Journal Name, Year",
    href: "#",
  },
];

const conferencePapers = [
  {
    title: "Add conference paper title here",
    authors: "Your Name, Coauthor Name, Coauthor Name",
    venue: "Conference Name, Year",
    href: "#",
  },
  {
    title: "Add another conference paper title here",
    authors: "Your Name, Coauthor Name",
    venue: "Conference Name, Year",
    href: "#",
  },
];

const preprints = [
  {
    title: "Add preprint / in-preparation title here",
    authors: "Your Name, Coauthor Name",
    venue: "Preprint / In Preparation",
    href: "#",
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Publications | Your Name</title>
    <meta
      name="description"
      content="Publications and scholarly output related to space autonomy, navigation, estimation, and AI/ML for engineering materials."
    />
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>

  <body class="bg-slate-950 text-white overflow-x-hidden">
    <!-- Top navigation -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-wide text-white">
          Your Name
        </a>

        <div class="hidden gap-6 text-sm text-slate-300 md:flex">
          <a href="/" class="transition hover:text-cyan-300">Home</a>
          <a href="/about" class="transition hover:text-cyan-300">About</a>
          <a href="/research" class="transition hover:text-cyan-300">Research</a>
          <a href="/publications" class="transition hover:text-cyan-300">Publications</a>
          <a href="/experience" class="transition hover:text-cyan-300">Experience</a>
          <a href="/news" class="transition hover:text-cyan-300">News</a>
          <a href="/#contact" class="transition hover:text-cyan-300">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <!-- Page hero -->
      <section class="relative overflow-hidden px-6 py-24">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-400/5 blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Publications
          </p>
          <h1 class="mt-4 text-4xl font-bold sm:text-5xl">
            Scholarly Output
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            A selection of publications across my current research directions,
            including space autonomy, navigation, estimation, and AI/ML for
            engineering materials.
          </p>
        </div>
      </section>

      <!-- Featured publications -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-6xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Featured Publications
          </p>
          <h2 class="mt-3 text-3xl font-bold">Highlighted work</h2>

          <div class="mt-10 grid gap-6">
            {featuredPublications.map((pub) => (
              <article class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-xl backdrop-blur">
                <h3 class="text-2xl font-semibold">{pub.title}</h3>
                <p class="mt-3 text-sm text-slate-400">{pub.authors}</p>
                <p class="mt-1 text-sm font-medium text-cyan-300/90">{pub.venue}</p>
                <p class="mt-4 leading-7 text-slate-300">{pub.description}</p>

                <div class="mt-6 flex flex-wrap gap-3">
                  {pub.links.map((link) => (
                    <a
                      href={link.href}
                      target={link.href.startsWith("http") ? "_blank" : "_self"}
                      rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                      class="rounded-xl border border-cyan-300/30 px-4 py-2 text-sm font-medium text-cyan-200 transition hover:bg-cyan-300/10"
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Journal papers -->
      <section class="px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Journal Papers
          </p>
          <h2 class="mt-3 text-3xl font-bold">Journal articles</h2>

          <div class="mt-10 space-y-5">
            {journalPapers.map((pub) => (
              <article class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <h3 class="text-lg font-semibold text-white">{pub.title}</h3>
                <p class="mt-2 text-sm text-slate-400">{pub.authors}</p>
                <p class="mt-1 text-sm text-cyan-300/90">{pub.venue}</p>
                <a
                  href={pub.href}
                  class="mt-4 inline-block text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
                >
                  View publication
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Conference papers -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Conference Papers
          </p>
          <h2 class="mt-3 text-3xl font-bold">Conference contributions</h2>

          <div class="mt-10 space-y-5">
            {conferencePapers.map((pub) => (
              <article class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <h3 class="text-lg font-semibold text-white">{pub.title}</h3>
                <p class="mt-2 text-sm text-slate-400">{pub.authors}</p>
                <p class="mt-1 text-sm text-cyan-300/90">{pub.venue}</p>
                <a
                  href={pub.href}
                  class="mt-4 inline-block text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
                >
                  View publication
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Preprints -->
      <section class="px-6 py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Preprints / In Preparation
          </p>
          <h2 class="mt-3 text-3xl font-bold">Ongoing work</h2>

          <div class="mt-10 space-y-5">
            {preprints.map((pub) => (
              <article class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <h3 class="text-lg font-semibold text-white">{pub.title}</h3>
                <p class="mt-2 text-sm text-slate-400">{pub.authors}</p>
                <p class="mt-1 text-sm text-cyan-300/90">{pub.venue}</p>
                <a
                  href={pub.href}
                  class="mt-4 inline-block text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
                >
                  View item
                </a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Closing -->
      <section class="border-t border-white/10 bg-slate-900/60 px-6 py-20">
        <div class="mx-auto max-w-5xl text-center">
          <p class="text-sm uppercase tracking-[0.3em] text-cyan-300/80">
            Research Profile
          </p>
          <h2 class="mt-3 text-3xl font-bold">A growing publication record</h2>
          <p class="mx-auto mt-6 max-w-3xl leading-8 text-slate-300">
            This page can expand over time as new journal papers, conference
            papers, preprints, and collaborative projects are added.
          </p>

          <a
            href="/research"
            class="mt-8 inline-block rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-medium text-white transition hover:border-cyan-300/40 hover:bg-cyan-300/10"
          >
            Explore research areas
          </a>
        </div>
      </section>
    </main>
  </body>
</html>